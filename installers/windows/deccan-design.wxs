<?xml version="1.0" encoding="UTF-8"?>
<!--
  deccan-design v2.0 — Windows MSI definition

  Per-user install (no admin elevation). Unsigned.
  Build with WiX Toolset v4.0.6: see installers/windows/build.ps1.

  Package version v2.0.1 — refresh that bundles the full skill tree
  (references, slot template, assets) which the v2.0.0 MSI omitted, and
  picks up the cover/end-page print-rendering fixes shipped to the
  repo. Design system version remains v2.0.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
      Name="deccan-design"
      Manufacturer="Deccan Fine Chemicals Pvt. Ltd."
      Version="2.0.1"
      UpgradeCode="72423D74-5D81-4CC6-8F5A-6AB4FFE65448"
      InstallerVersion="500"
      Scope="perUser"
      Compressed="yes">

    <SummaryInformation Description="deccan-design v2.0 — corporate design system for Deccan Fine Chemicals." />

    <MajorUpgrade DowngradeErrorMessage="A newer version of deccan-design is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <ui:WixUI Id="WixUI_Minimal" />

    <Property Id="ARPPRODUCTICON" Value="deccan.ico" />
    <Property Id="ARPHELPLINK" Value="https://github.com/kvkalidindi/deccan-design" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/kvkalidindi/deccan-design" />
    <Property Id="ARPNOREPAIR" Value="1" />

    <!-- Standard per-user folders -->
    <StandardDirectory Id="AppDataFolder">
      <!-- Office personal templates -->
      <Directory Id="MicrosoftDir" Name="Microsoft">
        <Directory Id="TemplatesDir" Name="Templates" />
        <Directory Id="SignaturesDir" Name="Signatures" />
      </Directory>
      <!-- Anthropic Claude skill location -->
      <Directory Id="AnthropicDir" Name="Anthropic">
        <Directory Id="ClaudeDir" Name="Claude">
          <Directory Id="ClaudeSkillsDir" Name="skills">
            <Directory Id="DeccanSkillDir" Name="deccan-design">
              <Directory Id="DeccanSkillRefsDir"      Name="references" />
              <Directory Id="DeccanSkillAssetsDir"    Name="assets">
                <Directory Id="DeccanSkillFontsDir"     Name="fonts" />
                <Directory Id="DeccanSkillTemplatesDir" Name="templates" />
              </Directory>
            </Directory>
          </Directory>
        </Directory>
      </Directory>
      <!-- deccan-design root (helpers, docs, assets) -->
      <Directory Id="DeccanRootDir" Name="deccan-design">
        <Directory Id="DeccanDocsDir"   Name="docs" />
        <Directory Id="DeccanAssetsDir" Name="assets" />
      </Directory>
    </StandardDirectory>

    <Feature Id="OfficeTemplates" Title="Office templates" Level="1">
      <Component Id="cmpDeccanDocumentDotx" Directory="TemplatesDir" Guid="*">
        <File Id="fDeccanDocumentDotx" Source="..\..\templates\word\deccan-document.dotx" />
      </Component>
      <Component Id="cmpDeccanTechnicalSpecDotx" Directory="TemplatesDir" Guid="*">
        <File Id="fDeccanTechnicalSpecDotx" Source="..\..\templates\word\deccan-technical-spec.dotx" />
      </Component>
      <Component Id="cmpDeccanPolicyDotx" Directory="TemplatesDir" Guid="*">
        <File Id="fDeccanPolicyDotx" Source="..\..\templates\word\deccan-policy.dotx" />
      </Component>
      <Component Id="cmpDeccanCustomerLetterDotx" Directory="TemplatesDir" Guid="*">
        <File Id="fDeccanCustomerLetterDotx" Source="..\..\templates\word\deccan-customer-letter.dotx" />
      </Component>

      <Component Id="cmpDeccanWorkbookXltx" Directory="TemplatesDir" Guid="*">
        <File Id="fDeccanWorkbookXltx" Source="..\..\templates\excel\deccan-workbook.xltx" />
      </Component>
      <Component Id="cmpDeccanComparisonXltx" Directory="TemplatesDir" Guid="*">
        <File Id="fDeccanComparisonXltx" Source="..\..\templates\excel\deccan-comparison.xltx" />
      </Component>
      <Component Id="cmpDeccanFinancialXltx" Directory="TemplatesDir" Guid="*">
        <File Id="fDeccanFinancialXltx" Source="..\..\templates\excel\deccan-financial-model.xltx" />
      </Component>

      <Component Id="cmpDeccanDeckPotx" Directory="TemplatesDir" Guid="*">
        <File Id="fDeccanDeckPotx" Source="..\..\templates\powerpoint\deccan-deck.potx" />
      </Component>
      <Component Id="cmpDeccanCustomerPitchPotx" Directory="TemplatesDir" Guid="*">
        <File Id="fDeccanCustomerPitchPotx" Source="..\..\templates\powerpoint\deccan-customer-pitch.potx" />
      </Component>
      <Component Id="cmpDeccanInternalReviewPotx" Directory="TemplatesDir" Guid="*">
        <File Id="fDeccanInternalReviewPotx" Source="..\..\templates\powerpoint\deccan-internal-review.potx" />
      </Component>

      <!-- Point Office at the personal templates folder -->
      <Component Id="cmpOfficePersonalTemplatesReg" Directory="TemplatesDir" Guid="*">
        <RegistryValue Root="HKCU"
                       Key="Software\Microsoft\Office\16.0\Common\General"
                       Name="PersonalTemplates"
                       Type="string"
                       Value="[%APPDATA]\Microsoft\Templates"
                       KeyPath="yes" />
      </Component>
    </Feature>

    <Feature Id="OutlookSignature" Title="Outlook signature template" Level="1">
      <Component Id="cmpOutlookSigHtm" Directory="SignaturesDir" Guid="*">
        <File Id="fOutlookSigHtm" Source="..\..\templates\outlook\deccan-signature.htm"
              Name="deccan-signature-template.htm" />
      </Component>
      <Component Id="cmpOutlookSigTxt" Directory="SignaturesDir" Guid="*">
        <File Id="fOutlookSigTxt" Source="..\..\templates\outlook\deccan-signature.txt"
              Name="deccan-signature-template.txt" />
      </Component>
      <Component Id="cmpSetSignaturePs1" Directory="DeccanRootDir" Guid="*">
        <File Id="fSetSignaturePs1" Source="Set-DeccanSignature.ps1" />
      </Component>
    </Feature>

    <Feature Id="ClaudeSkill" Title="Claude skill (SKILL.md + references + slot template + assets)" Level="1">
      <Component Id="cmpSkillMd" Directory="DeccanSkillDir" Guid="*">
        <File Id="fSkillMd" Source="..\..\skill\SKILL.md" />
      </Component>
      <!-- Skill reference modules -->
      <Component Id="cmpSkillRefTokens" Directory="DeccanSkillRefsDir" Guid="*">
        <File Id="fSkillRefTokens" Source="..\..\skill\references\tokens.md" />
      </Component>
      <Component Id="cmpSkillRefComponents" Directory="DeccanSkillRefsDir" Guid="*">
        <File Id="fSkillRefComponents" Source="..\..\skill\references\components.md" />
      </Component>
      <Component Id="cmpSkillRefPrintRules" Directory="DeccanSkillRefsDir" Guid="*">
        <File Id="fSkillRefPrintRules" Source="..\..\skill\references\print-rules.md" />
      </Component>
      <Component Id="cmpSkillRefToneAndVoice" Directory="DeccanSkillRefsDir" Guid="*">
        <File Id="fSkillRefToneAndVoice" Source="..\..\skill\references\tone-and-voice.md" />
      </Component>
      <Component Id="cmpSkillRefDocumentTemplates" Directory="DeccanSkillRefsDir" Guid="*">
        <File Id="fSkillRefDocumentTemplates" Source="..\..\skill\references\document-templates.md" />
      </Component>
      <!-- Slot-fill HTML template + companion docs -->
      <Component Id="cmpSkillTplDocument" Directory="DeccanSkillTemplatesDir" Guid="*">
        <File Id="fSkillTplDocument" Source="..\..\skill\assets\templates\document.html" />
      </Component>
      <Component Id="cmpSkillTplSlots" Directory="DeccanSkillTemplatesDir" Guid="*">
        <File Id="fSkillTplSlots" Source="..\..\skill\assets\templates\document-slots.md" />
      </Component>
      <Component Id="cmpSkillTplReadme" Directory="DeccanSkillTemplatesDir" Guid="*">
        <File Id="fSkillTplReadme" Source="..\..\skill\assets\templates\README.md" />
      </Component>
      <!-- Fonts dir README — keeps the directory present and documents the OS-native policy -->
      <Component Id="cmpSkillFontsReadme" Directory="DeccanSkillFontsDir" Guid="*">
        <File Id="fSkillFontsReadme" Source="..\..\skill\assets\fonts\README.md" />
      </Component>
      <!-- Logo assets live under skill/assets directly -->
      <Component Id="cmpSkillLogoSvg" Directory="DeccanSkillAssetsDir" Guid="*">
        <File Id="fSkillLogoSvg" Source="..\..\skill\assets\logo.svg" />
      </Component>
      <Component Id="cmpSkillLogoPng" Directory="DeccanSkillAssetsDir" Guid="*">
        <File Id="fSkillLogoPng" Source="..\..\skill\assets\logo.png" />
      </Component>
      <Component Id="cmpSkillLogoB64" Directory="DeccanSkillAssetsDir" Guid="*">
        <File Id="fSkillLogoB64" Source="..\..\skill\assets\logo.b64.txt" />
      </Component>
    </Feature>

    <Feature Id="DocsAndAssets" Title="Documentation and assets" Level="1">
      <Component Id="cmpReadme" Directory="DeccanDocsDir" Guid="*">
        <File Id="fReadme" Source="..\..\README.md" />
      </Component>
      <Component Id="cmpPreferencesReminder" Directory="DeccanRootDir" Guid="*">
        <File Id="fPreferencesReminder" Source="preferences-reminder.txt" />
      </Component>
      <Component Id="cmpPersonalPreferences" Directory="DeccanDocsDir" Guid="*">
        <File Id="fPersonalPreferences" Source="..\..\claude\personal-preferences.md" />
      </Component>
      <Component Id="cmpCopyright" Directory="DeccanDocsDir" Guid="*">
        <File Id="fCopyright" Source="..\..\COPYRIGHT.md" />
      </Component>
      <Component Id="cmpLogoPng" Directory="DeccanAssetsDir" Guid="*">
        <File Id="fLogoPng" Source="..\..\skill\assets\logo.png" Name="logo.png" />
      </Component>
      <Component Id="cmpLogoSvg" Directory="DeccanAssetsDir" Guid="*">
        <File Id="fLogoSvg" Source="..\..\skill\assets\logo.svg" Name="logo.svg" />
      </Component>
    </Feature>

    <Feature Id="VersionMarker" Title="Version marker" Level="1">
      <Component Id="cmpVersionReg" Directory="DeccanRootDir" Guid="*">
        <RegistryValue Root="HKCU" Key="Software\deccan-design"
                       Name="Version" Value="2.0.1" Type="string" KeyPath="yes" />
        <RegistryValue Root="HKCU" Key="Software\deccan-design"
                       Name="InstallPath" Type="string"
                       Value="[%APPDATA]\deccan-design" />
        <RegistryValue Root="HKCU" Key="Software\deccan-design"
                       Name="DesignSystemVersion" Type="string"
                       Value="2.0" />
      </Component>
    </Feature>

  </Package>
</Wix>
